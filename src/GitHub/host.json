{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      },
      "enableLiveMetricsFilters": true
    }
  },
  "extensions": {
    "mcp": {
      "system": {
        "webhookAuthorizationLevel": "Anonymous"
      },
      "serverName": "GitHub MCP Server",
      "serverVersion": "1.0.0",
      "instructions": "MCP server for interacting with GitHub repositories, issues, and pull requests. Set GITHUB_TOKEN environment variable for authenticated access."
    }
  }
}
